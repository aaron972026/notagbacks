{
  "name": "server",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "sync:shared": "node scripts/sync-shared.mjs",
    "dev": "npm run sync:shared && tsx watch src/index.ts",
    "build": "npm run sync:shared && esbuild src/index.ts --bundle --platform=node --format=esm --target=node20 --packages=external --outfile=build/index.js --sourcemap",
    "start": "npm run build && node --enable-source-maps build/index.js",
    "typecheck": "npm run sync:shared && tsc --noEmit"
  },
  "dependencies": {
    "@colyseus/schema": "^3.0.0",
    "@colyseus/tools": "^0.16.0",
    "@colyseus/ws-transport": "^0.16.5",
    "colyseus": "^0.16.5",
    "esbuild": "^0.24.0",
    "express": "^4.21.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
